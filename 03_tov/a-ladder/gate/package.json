{
  "name": "cpisi-gate",
  "version": "1.5.0",
  "description": "Sanctuary Gate Frontend - Unified Web & Mobile",
  "main": "src/index.ts",
  "author": "Creative Workz Studio LLC",
  "license": "UNLICENSED",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=js/bundle.js --minify --sourcemap --platform=browser",
    "dev": "esbuild src/index.ts --bundle --outfile=js/bundle.js --sourcemap --platform=browser --watch",
    "ionic:build": "npm run build",
    "ionic:serve": "npm run dev",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.1",
    "typescript": "^5.4.2"
  }
}
