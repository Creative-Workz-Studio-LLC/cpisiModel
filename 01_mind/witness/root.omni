    map "02_argument/" as the logical defense of the unified model                   // ║ ║ [MAP: ARGUMENT]             ║
    map "03_axiomatic_proofs/" as the physical Court of 36 witnesses                // ║ ║ [MAP: PROOFS]               ║
                                                                                     // ║ ║                              ║
    link court THE_SEALED_36 to "01_mind/witness/03_axiomatic_proofs/"               // ║ ║ [LNK: THE_36]               ║
